---
import { Image } from "astro:assets";
import { SIGNUP_URL, type City } from "../data/cities";
import heroLogo from "../assets/images/Kiwihacks_-_Nova_Logo_2.png";
import img1 from "../assets/images/DSCF3841.jpg";
import img2 from "../assets/images/DSCF4012.jpg";
import img3 from "../assets/images/DSCF2200.jpg";
import img4 from "../assets/images/DSCF3768.jpg";
import img5 from "../assets/images/DSCF3771.jpg";
import img6 from "../assets/images/DSCF7194.jpg";

const { city } = Astro.props;

const galleryImages = [img1, img2, img3, img4, img5, img6];
---

<div
  class="mx-auto flex max-w-5xl flex-col items-center px-5 pt-16 pb-24 text-center sm:pt-24"
>
  <Image
    src={heroLogo}
    alt="KiwiHacks presents Nova"
    width={448}
    height={448}
    fetchpriority="high"
    loading="eager"
    class="h-80 w-auto select-none sm:h-[28rem]"
  />

  <p class="mt-8 max-w-2xl text-xl text-white sm:text-2xl">
    {city.name}&apos;s free 24-hour hackathon for high school students
  </p>

  <div
    class="mt-7 w-full rounded-[2rem] bg-[#aa4176] px-6 py-7 text-center shadow-lg"
  >
    <p
      class="text-lg font-semibold uppercase tracking-wide text-white sm:text-2xl"
    >
      {city.name}
      {"  ·  "}
      {city.date}
      {"  ·  "}Location TBC
    </p>
  </div>

  <div class="mt-9">
    <a
      href={SIGNUP_URL}
      class="inline-block rounded-2xl bg-[#4f46e5] px-12 py-4 text-lg font-semibold text-white no-underline shadow-lg transition-colors hover:bg-[#5b52ee]"
    >
      Sign up for Nova!
    </a>
  </div>

  <section class="mt-24 w-full">
    <h2 class="text-center text-4xl font-semibold text-white sm:text-5xl">
      About Nova
    </h2>

    <div
      class="mx-auto mt-8 max-w-3xl space-y-5 text-left text-lg leading-relaxed text-white/85 sm:text-xl"
    >
      <p>
        KiwiHacks Nova is a constellation of three hackathons across New
        Zealand. Three cities, three weekends, three free 24-hour hackathons for
        high schoolers. A nova is a star that suddenly bursts bright, and
        that&apos;s the idea: light up Wellington, Christchurch, and Auckland
        with students building real things.
      </p>
      <p>
        Nova is a chance to meet new people, learn new skills, and build
        something you&apos;re actually proud of, whether that&apos;s an app, a
        game, a website, a hardware project, or something nobody has seen
        before! You team up, you get 24 hours, and you ship. Mentors will be
        around for the entire event, and beginner-friendly workshops mean you
        don't need any prior experience to get started. Food, drinks, and swag
        are all included, and everything is completely free!
      </p>
      <p>
        We're KiwiHacks, New Zealand&apos;s first high school hackathon club,
        built and run entirely by teenagers! At KiwiHacks &rsquo;26 earlier this
        year, over 100 high schoolers turned up and every team left with a
        shipped project they were proud of. Plus, all of them made a new friend.
        Nova takes that across the country. Whatever your skill level, you are
        welcome. Just sign up, show up, and give it a go.
      </p>
    </div>

    <div class="group relative mt-12" data-carousel>
      {/* Track — scrollbar hidden across all browsers */}
      <div
        data-carousel-track
        class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth rounded-2xl shadow-2xl ring-1 ring-white/10 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
      >
        {
          galleryImages.map((src, index) => (
            <div class="relative aspect-[16/9] w-full shrink-0 snap-center overflow-hidden">
              <Image
                src={src}
                alt="KiwiHacks event photo"
                width={960}
                height={640}
                loading={index === 0 ? "eager" : "lazy"}
                class={`h-full w-full object-cover ${index === galleryImages.length - 1 ? "origin-left scale-110 object-left" : ""}`}
              />
              {/* Bottom vignette for depth */}
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-black/40 to-transparent" />
            </div>
          ))
        }
      </div>

      {/* Photo counter */}
      <div
        data-carousel-counter
        class="absolute right-4 bottom-4 rounded-full bg-black/50 px-3 py-1 text-xs font-medium tabular-nums text-white/80 backdrop-blur-sm"
      >
        1 / {galleryImages.length}
      </div>

      {/* Prev arrow — always visible on mobile, fades in on desktop hover */}
      <button
        type="button"
        data-carousel-prev
        aria-label="Previous photo"
        class="absolute top-1/2 left-4 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-black/60 text-white transition-all duration-200 hover:scale-110 hover:bg-black/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 sm:opacity-0 sm:group-hover:opacity-100 sm:group-focus-within:opacity-100"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
          <path
            d="M15 6l-6 6 6 6"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      {/* Next arrow */}
      <button
        type="button"
        data-carousel-next
        aria-label="Next photo"
        class="absolute top-1/2 right-4 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-black/60 text-white transition-all duration-200 hover:scale-110 hover:bg-black/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 sm:opacity-0 sm:group-hover:opacity-100 sm:group-focus-within:opacity-100"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
          <path
            d="M9 6l6 6-6 6"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      {/* Dot indicators — active dot expands to a pill */}
      <div class="mt-4 flex items-center justify-center gap-1.5">
        {
          galleryImages.map((_, index) => (
            <button
              type="button"
              data-carousel-dot={index}
              aria-label={`Go to photo ${index + 1}`}
              class="flex h-6 w-6 items-center justify-center rounded-full"
            >
              <span
                data-carousel-dot-inner
                class="block h-2.5 w-2.5 rounded-full bg-white/30 transition-colors"
              />
            </button>
          ))
        }
      </div>
    </div>
  </section>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>("[data-carousel-track]");
    const prev = root.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const next = root.querySelector<HTMLButtonElement>("[data-carousel-next]");
    const counter = root.querySelector<HTMLElement>("[data-carousel-counter]");
    const dots = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]"),
    );
    if (!track) return;

    const slideCount = track.children.length;
    let activeIndex = 0;
    let autoplay: ReturnType<typeof setInterval> | undefined;

    function setActive(index: number) {
      activeIndex = (index + slideCount) % slideCount;
      if (counter) counter.textContent = `${activeIndex + 1} / ${slideCount}`;
      dots.forEach((dot, i) => {
        dot.toggleAttribute("data-active", i === activeIndex);
        const inner = dot.querySelector<HTMLElement>(
          "[data-carousel-dot-inner]",
        );
        if (inner) {
          inner.classList.toggle("w-6", i === activeIndex);
          inner.classList.toggle("bg-white", i === activeIndex);
          inner.classList.toggle("w-2", i !== activeIndex);
          inner.classList.toggle("bg-white/30", i !== activeIndex);
        }
      });
    }

    function goTo(index: number, smooth = true) {
      setActive(index);
      const slide = track?.children[activeIndex] as HTMLElement | undefined;
      if (slide) {
        track?.scrollTo({
          left: slide.offsetLeft,
          behavior: smooth ? "smooth" : "auto",
        });
      }
    }

    function startAutoplay() {
      stopAutoplay();
      autoplay = setInterval(() => goTo(activeIndex + 1), 6000);
    }

    function stopAutoplay() {
      if (autoplay) clearInterval(autoplay);
    }

    prev?.addEventListener("click", () => {
      goTo(activeIndex - 1);
      startAutoplay();
    });

    next?.addEventListener("click", () => {
      goTo(activeIndex + 1);
      startAutoplay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        goTo(i);
        startAutoplay();
      });
    });

    track.addEventListener("scroll", () => {
      const index = Math.round(track.scrollLeft / track.clientWidth);
      setActive(index);
    });

    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);

    setActive(0);
    startAutoplay();
  });
</script>
