---
import NovaLogo from "./NovaLogo.astro";
import { CITIES, DEFAULT_CITY_SLUG, cityBySlug } from "../data/cities";

// Current city is derived from the URL. "/" defaults to Auckland.
// On non-city routes (e.g. /faq) there is no active city, so the button reads "Select City".
const pathname = Astro.url.pathname;
const normalized = pathname.replace(/\/$/, "") || "/";
const slug =
  normalized === "/" ? DEFAULT_CITY_SLUG : normalized.replace(/^\//, "");
const activeCity = cityBySlug(slug) ?? null;
---

<!-- The bar plus its bright pink gradient underline strip. -->
<header class="sticky top-0 z-50 w-full">
  <nav
    class="flex w-full flex-wrap items-center justify-between gap-3 bg-[#161a3d] px-4 py-3 sm:flex-nowrap sm:px-8 sm:py-2.5"
  >
    {/* Left: Nova wordmark, links home */}
    <a href="/" class="flex items-center gap-2 no-underline">
      <NovaLogo class="h-12 sm:h-14" />
    </a>

    <button
      type="button"
      data-mobile-menu-toggle
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[#4f46e5] text-white transition-colors hover:bg-[#5b52ee] sm:hidden"
    >
      <span class="sr-only">Open menu</span>
      <svg viewBox="0 0 24 24" fill="none" class="h-7 w-7" aria-hidden="true">
        <path
          d="M4 7h16M4 12h16M4 17h16"
          stroke="white"
          stroke-width="2.5"
          stroke-linecap="round"></path>
      </svg>
    </button>

    {/* Right: Team, FAQ, Select City */}
    <div
      id="mobile-menu"
      data-mobile-menu
      class="hidden w-full flex-col gap-2 rounded-2xl bg-white/5 p-2 ring-1 ring-white/10 sm:flex sm:w-auto sm:flex-row sm:items-center sm:gap-3 sm:bg-transparent sm:p-0 sm:ring-0"
    >
      {/* Team has no page yet, so it's a non-navigating button. */}
      <button
        type="button"
        class="w-full rounded-xl bg-[#4f46e5] px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[#5b52ee] sm:w-auto sm:px-5 sm:py-2"
      >
        Team
      </button>

      <a
        href="/faq"
        class="block w-full rounded-xl bg-[#4f46e5] px-4 py-2.5 text-center text-sm font-medium text-white no-underline transition-colors hover:bg-[#5b52ee] sm:w-auto sm:px-5 sm:py-2"
      >
        FAQ
      </a>

      {/* Select City dropdown: each option navigates to /{slug} */}
      <div class="relative w-full sm:w-auto" data-city-dropdown>
        <button
          type="button"
          data-city-toggle
          aria-expanded="false"
          class="flex w-full items-center justify-center gap-3 rounded-xl bg-[#4f46e5] px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[#5b52ee] sm:w-auto sm:px-5 sm:py-2"
        >
          <span class="truncate whitespace-nowrap">
            {activeCity ? activeCity.name : "Select City"}
          </span>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            class="h-6 w-6 shrink-0 transition-transform"
            data-city-chevron
            aria-hidden="true"
          >
            <path
              d="M5 9l7 7 7-7"
              stroke="white"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>

        <div
          data-city-panel
          hidden
          class="absolute right-0 top-[calc(100%+0.4rem)] z-50 w-full min-w-64 max-w-[calc(100vw-2rem)] overflow-hidden rounded-xl bg-[#4f4fc8] py-1 shadow-2xl ring-1 ring-black/20 sm:w-64"
        >
          {
            CITIES.map((city) => (
              <a
                href={`/${city.slug}`}
                class="flex w-full items-baseline justify-between gap-4 px-4 py-1.5 text-left no-underline transition-colors hover:bg-white/10"
              >
                <span class="text-lg text-white">{city.name}</span>
                <span class="text-xs text-white/70">{city.date}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </nav>

  {/* Bright pink gradient underline strip beneath the bar. */}
  <div
    class="h-[3px] w-full bg-gradient-to-r from-[#ff5ea0] via-[#ff7ab3] to-[#ff5ea0]"
  >
  </div>
</header>

<script>
  const mobileMenuToggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-menu-toggle]",
  );
  const mobileMenu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  function setMobileMenuOpen(open: boolean) {
    if (!mobileMenu || !mobileMenuToggle) return;
    mobileMenu.classList.toggle("hidden", !open);
    mobileMenu.classList.toggle("flex", open);
    mobileMenuToggle.setAttribute("aria-expanded", String(open));
  }

  mobileMenuToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    setMobileMenuOpen(mobileMenu?.classList.contains("hidden") ?? true);
  });

  // Select City dropdown: toggle open/close on click, close on outside-click.
  const root = document.querySelector<HTMLElement>("[data-city-dropdown]");
  const toggle =
    document.querySelector<HTMLButtonElement>("[data-city-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-city-panel]");
  const chevron = document.querySelector<SVGElement>("[data-city-chevron]");

  function setOpen(open: boolean) {
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", String(open));
    if (chevron) chevron.classList.toggle("rotate-180", open);
  }

  toggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    setOpen(panel?.hidden ?? false);
  });

  document.addEventListener("mousedown", (e) => {
    if (root && !root.contains(e.target as Node)) setOpen(false);
    if (
      mobileMenu &&
      mobileMenuToggle &&
      !mobileMenu.contains(e.target as Node) &&
      !mobileMenuToggle.contains(e.target as Node)
    ) {
      setMobileMenuOpen(false);
    }
  });
</script>
