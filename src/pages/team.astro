---

<Layout
  title="KiwiHacks Nova | Team"
  description="Meet the KiwiHacks Nova team."
>
  <div class="mx-auto max-w-5xl px-5 pt-6 pb-24">
    <BackButton />

    <div
      class="mt-8 flex flex-wrap items-center justify-center gap-4 sm:justify-start"
    >
      <NovaLogo class="h-20 w-auto sm:h-24" />
      <h1 class="text-5xl font-semibold text-white sm:text-7xl">Team</h1>
    </div>

    <section class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        members.map((member) => (
          <article class="overflow-hidden rounded-xl bg-[#5c2a42]/85 ring-1 ring-white/5">
            <img
              src={member.image}
              alt={member.name}
              class="h-[26rem] w-full rounded-xl bg-[#4b1e36] object-contain p-2 sm:h-[30rem]"
              loading="lazy"
              draggable="false"
            />
            <div class="p-6">
              <h2 class="text-lg font-semibold text-[#db74a8]">
                {member.name}
              </h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {member.links.map((link) => (
                  <a
                    href={link.href}
                    class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-white/90 text-[#4b58ce] ring-1 ring-black/5 transition-colors hover:bg-white"
                    aria-label={link.label}
                    target={link.href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      link.href.startsWith("http") ? "noreferrer" : undefined
                    }
                  >
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-4.5 w-4.5"
                      aria-hidden="true"
                    >
                      <path d={socialIcons[link.label]} />
                    </svg>
                  </a>
                ))}
              </div>
              <p class="mt-4 text-sm leading-relaxed text-white/80">
                {member.bio}
              </p>
            </div>
          </article>
        ))
      }
    </section>
  </div>
</Layout>
