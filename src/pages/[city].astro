---
import Layout from "../layouts/Layout.astro";
import CityHome from "../components/CityHome.astro";
import { CITIES, cityBySlug } from "../data/cities";

// Pre-render one static page per city: /wellington, /christchurch, /auckland.
export function getStaticPaths() {
  return CITIES.map((c) => ({ params: { city: c.slug } }));
}

const { city } = Astro.params;
const found = cityBySlug(city ?? "");

// Unknown slug -> 404.
if (!found) {
  return Astro.redirect("/404");
}

const title = `Nova ${found.name} | KiwiHacks`;
---

<Layout title={title}>
  <CityHome city={found} />
</Layout>
